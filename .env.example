# === Memory Layer Configuration ===

# Google API key for Gemini 2.0 Flash graph extraction
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic API key for Claude Haiku compression worker
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Server settings
HOST=0.0.0.0
PORT=8000

# Database root directory (per-tenant DBs stored here)
DB_ROOT=./db

# Ollama settings (local embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Rate limiting
RATE_LIMIT_RPM=60

# Dashboard
DASHBOARD_PORT=37777
